{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "ChatSession": {
      "title": "ChatSession",
      "description": "A chat session with the AI assistant",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "createdAt", "updatedAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A single message in a chat session",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sessionId", "role", "text", "createdAt"]
    },
    "Inquiry": {
      "title": "Inquiry",
      "description": "A contact inquiry from a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "department": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "department", "message", "status", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profiles"
    },
    "chatSessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Stores chat sessions for users"
    },
    "chatSessions/{sessionId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Stores messages within a chat session"
    },
    "inquiries/{inquiryId}": {
      "schema": "Inquiry",
      "description": "Stores user inquiries"
    }
  }
}
